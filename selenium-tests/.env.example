# Selenium E2E Test Configuration
# Copy this to .env and fill in values

# Base URL for the deployed application
# ⚠️ MUST be the GitHub Pages URL — NOT localhost
BASE_URL=https://Viru-6281.github.io/spic-pdd/

# Headless mode (true = no browser window, required for CI)
HEADLESS=true

# Timeout in milliseconds
TIMEOUT=30000

# Screenshot output directory
SCREENSHOT_DIR=../Test Results/Screenshots

# Log output directory
LOG_DIR=../Test Results/Logs
